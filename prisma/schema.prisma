model user_mfa {
  user_id        String   @id
  secret         String
  enabled        Boolean  @default(false)
  backup_codes   String?
  organizationId String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("user_mfa")
}

model PatientPasswordSetupToken {
  id             String    @id @default(uuid())
  token_hash     String    @unique
  patient_id     String
  organizationId String
  expires_at     DateTime
  used_at        DateTime?
  created_at     DateTime  @default(now())

  patient      OPD_REG      @relation(fields: [patient_id], references: [patient_id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([patient_id, organizationId])
  @@index([expires_at])
  @@map("patient_password_setup_tokens")
}

// ========================================
// MODULE — Vitals
// ========================================

model vital_signs {
  id               Int      @id @default(autoincrement())
  patient_id       String
  appointment_id   String?
  blood_pressure   String?
  heart_rate       Int?
  temperature      Float?
  oxygen_sat       Int?
  respiratory_rate Int?
  weight           Float?
  height           Float?
  recorded_by      String?
  organizationId   String
  created_at       DateTime @default(now())
  // Phase 3 — extended vitals
  blood_sugar      Float?
  pain_scale       Int? // 0–10
  encounter_id     String? // link to ClinicalEncounter

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([patient_id])
}

// ========================================
// MODULE — AI Health Assessment
// ========================================

model AiHealthAssessment {
  id                      String   @id @default(uuid())
  organizationId          String
  patient_id              String?
  session_token           String   @unique
  responses               String? // JSON string of Q&A
  ai_summary              String?
  risk_level              String? // LOW, MODERATE, HIGH, CRITICAL
  recommended_tests       String? // JSON string
  recommended_specialties String? // JSON string
  status                  String   @default("in_progress") // in_progress, completed
  created_at              DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("ai_health_assessments")
}

// ========================================
// MODULE — Appointment Slots
// ========================================

model AppointmentSlot {
  id             String   @id @default(uuid())
  organizationId String
  doctor_id      String
  date           DateTime
  start_time     String // "09:00"
  end_time       String // "09:30"
  slot_type      String   @default("walkin") // walkin, scheduled, blocked
  is_available   Boolean  @default(true)
  is_booked      Boolean  @default(false)
  booked_by      String? // patient_id
  created_at     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  doctor       User         @relation(fields: [doctor_id], references: [id])

  @@index([organizationId])
  @@index([doctor_id, date])
  @@map("appointment_slots")
}

// ========================================
// MODULE — Departments
// ========================================

model Department {
  id                    String   @id @default(uuid())
  name                  String
  slug                  String
  head_doctor_id        String?
  base_consultation_fee Float    @default(500)
  is_active             Boolean  @default(true)
  organizationId        String
