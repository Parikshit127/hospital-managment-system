generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========================================
// MODULE — Multi-Tenant (Organization)
// ========================================

model Organization {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  code       String   @unique
  address    String?
  phone      String?
  email      String?
  license_no String?
  logo_url   String?
  is_active  Boolean  @default(true)
  plan       String   @default("free") // free, starter, pro, enterprise
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  config   OrganizationConfig?
  branding OrganizationBranding?

  users                         User[]
  patients                      OPD_REG[]
  appointments                  appointments[]
  clinical_ehrs                 Clinical_EHR[]
  vital_signs                   vital_signs[]
  triage_results                triage_results[]
  lab_orders                    lab_orders[]
  lab_test_inventory            lab_test_inventory[]
  lab_staff                     lab_staff[]
  lab_audit_logs                lab_audit_logs[]
  pharmacy_medicine_master      pharmacy_medicine_master[]
  pharmacy_orders               pharmacy_orders[]
  pharmacy_sales_audit          pharmacy_sales_audit[]
  admissions                    admissions[]
  medical_notes                 medical_notes[]
  discharge_summaries           discharge_summaries[]
  beds                          beds[]
  wards                         wards[]
  invoices                      invoices[]
  invoice_items                 invoice_items[]
  payments                      payments[]
  payment_order_intents         PaymentOrderIntent[]
  billing_records               billing_records[]
  charge_catalog                charge_catalog[]
  insurance_providers           insurance_providers[]
  insurance_policies            insurance_policies[]
  insurance_claims              insurance_claims[]
  system_audit_logs             system_audit_logs[]
  user_mfa_records              user_mfa[]
  patient_password_setup_tokens PatientPasswordSetupToken[]
  ai_health_assessments         AiHealthAssessment[]
  appointment_slots             AppointmentSlot[]
  departments                   Department[]
  prescription_templates        PrescriptionTemplate[]
  follow_ups                    FollowUp[]
  lab_sample_tracking           LabSampleTracking[]
  lab_reagent_inventory         LabReagentInventory[]
  pharmacy_suppliers            PharmacySupplier[]
  purchase_orders               PurchaseOrder[]
  pharmacy_returns              PharmacyReturn[]
  bed_transfers                 BedTransfer[]
  diet_plans                    DietPlan[]
  ward_rounds                   WardRound[]
  nursing_tasks                 NursingTask[]
  patient_feedbacks             PatientFeedback[]
  cash_closures                 CashClosure[]
  refunds                       Refund[]
  // Phase 3 models
  nursing_notes                 NursingNote[]
  medication_administrations    MedicationAdministration[]
  shift_handovers               ShiftHandover[]
  opd_configs                   OPDConfig[]
  employees                     Employee[]
  attendances                   Attendance[]
  leave_types                   LeaveType[]
  leave_requests                LeaveRequest[]
  shift_patterns                ShiftPattern[]
  shift_assignments             ShiftAssignment[]
  notifications                 Notification[]
  expense_categories            ExpenseCategory[]
  vendors                       Vendor[]
  expenses                      Expense[]
  tax_configs                   TaxConfig[]
  patient_deposits              PatientDeposit[]
  credit_notes                  CreditNote[]
  financial_periods             FinancialPeriod[]
  bank_transactions             BankTransaction[]
  dunning_rules                 DunningRule[]
  dunning_logs                  DunningLog[]
  ipd_service_masters           IpdServiceMaster[]
  ipd_tariff_rates              IpdTariffRate[]
  ipd_packages                  IpdPackage[]
  ipd_admission_packages        IpdAdmissionPackage[]
  ipd_estimates                 IpdEstimate[]
  ipd_charge_postings           IpdChargePosting[]
  branches                      Branch[]
  // Admin panel dynamic configuration
  module_configs                ModuleConfig[]
  custom_roles                  Role[]
  document_templates            DocumentTemplate[]
  alert_rules                   AlertRule[]
  // Data import & archival
  data_import_jobs              DataImportJob[]
  archived_patient_records      ArchivedPatientRecord[]
  // Zealthix insurance integration
  zealthix_api_keys             ZealthixApiKey[]
  pill_reminders                PillReminder[]
  message_delivery_logs         MessageDeliveryLog[]
  whatsapp_incoming_msgs        WhatsAppIncomingMessage[]
  video_call_requests           VideoCallRequest[]
  // Phase 1 — Corporate & Pre-Authorization
  corporate_masters             CorporateMaster[]
  pre_authorizations            PreAuthorization[]
  // Phase 2 — Payment Splits
  payment_splits                PaymentSplit[]
  // Phase 3 — EMR
  clinical_encounters           ClinicalEncounter[]
  patient_allergies             PatientAllergy[]
  // IPD Upgrade
  ipd_vitals                    IPDVitals[]
  nursing_assessments           NursingAssessment[]
  insurance_preauths            InsurancePreAuth[]
  admission_consultants         AdmissionConsultant[]
  // Finance: GST Compliance
  gst_invoice_register          GST_Invoice_Register[]
  gst_return_filings            GST_Return_Filing[]
  hsn_sac_master                HSN_SAC_Master[]
  // Finance: General Ledger & Tally Integration
  gl_accounts                   GL_Account[]
  gl_journal_entries            GL_JournalEntry[]
  gl_journal_lines              GL_JournalLine[]
  tally_exports                 TallyExport[]
  // Finance: Fixed Asset Management
  asset_categories              AssetCategory[]
  fixed_assets                  FixedAsset[]
  depreciation_entries          DepreciationEntry[]
  asset_transfers               AssetTransfer[]
  asset_maintenance             AssetMaintenance[]
  // Finance: Budget Management
  budget_masters                BudgetMaster[]
  budget_lines                  BudgetLine[]
  budget_revisions              BudgetRevision[]
  budget_alerts                 BudgetAlert[]


  // Extended hospital profile fields
  hospital_type          String? // General, Multi-Specialty, Super-Specialty, Clinic, Nursing Home
  bed_capacity           Int?
  accreditation_body     String? // NABH, NABL, JCI, ISO
  accreditation_number   String?
  accreditation_expiry   DateTime?
  registration_number    String?
  registration_authority String?
  established_year       Int?
  organization_gstin     String?
  gst_state_code         String?
  website                String?
  specialties            String[]  @default([])
  latitude               Float?
  longitude              Float?

  @@map("organizations")
}

model Branch {
  id             String   @id @default(uuid())
  branch_name    String
  branch_code    String
  address        String?
  city           String?
  state          String?
  pincode        String?
  phone          String?
  email          String?
  is_main_branch Boolean  @default(false)
  is_active      Boolean  @default(true)
  latitude       Float?
  longitude      Float?
  organizationId String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("branches")
}

model SubscriptionPlan {
  id                     String   @id @default(uuid())
  plan_name              String
  plan_code              String   @unique // free, starter, pro, enterprise
  max_users              Int      @default(0) // 0 = unlimited
  max_branches           Int      @default(0)
  max_patients_per_month Int?
  features               String[] @default([])
  price_monthly          Float    @default(0)
  price_yearly           Float    @default(0)
  is_active              Boolean  @default(true)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  @@map("subscription_plans")
}

model OrganizationConfig {
  id                            String  @id @default(uuid())
  organizationId                String  @unique
  uhid_prefix                   String  @default("AVN")
  timezone                      String  @default("Asia/Kolkata")
  currency                      String  @default("INR")
  date_format                   String  @default("DD/MM/YYYY")
  session_timeout               Int     @default(15)
  enable_whatsapp               Boolean @default(false)
  enable_razorpay               Boolean @default(false)
  enable_ai_triage              Boolean @default(true)
  razorpay_key_id               String?
  razorpay_key_secret           String?
  smtp_host                     String?
  smtp_user                     String?
  smtp_pass                     String?
  whatsapp_api_token            String?
  whatsapp_phone_id             String?
  whatsapp_webhook_verify_token String?
  whatsapp_app_secret           String?
  openai_key                    String?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("organization_configs")
}

model OrganizationBranding {
  id              String  @id @default(uuid())
  organizationId  String  @unique
  primary_color   String  @default("#10b981")
  secondary_color String  @default("#0f172a")
  logo_url        String?
  portal_title    String  @default("Hospital OS")
  portal_subtitle String  @default("Management System")
  footer_text     String?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("organization_brandings")
}

// ========================================
// MODULE — Admin Panel Dynamic Configuration
// ========================================

model ModuleConfig {
  id             String   @id @default(uuid())
  organizationId String
  module_key     String // 'opd', 'ipd', 'lab', 'pharmacy', 'finance', 'hr', 'insurance', 'patient_portal'
  enabled        Boolean  @default(true)
  config_json    Json     @default("{}")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, module_key])
  @@index([organizationId])
  @@map("module_configs")
}

model Role {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String
  is_system      Boolean  @default(false)
  is_active      Boolean  @default(true)
  permissions    Json     @default("[]")
  data_scope     String   @default("own") // own, department, branch, organization
  description    String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique // 'opd.view', 'opd.create', 'billing.approve_discount'
  module      String // 'opd', 'ipd', 'lab', 'pharmacy', 'finance', 'admin', 'hr'
  action      String // 'view', 'create', 'edit', 'delete', 'approve', 'export'
  label       String
  description String?

  @@map("permissions")
}

model DocumentTemplate {
  id             String   @id @default(uuid())
  organizationId String
  type           String // 'prescription', 'invoice', 'discharge_summary', 'lab_report', 'consent_form', 'referral', 'medical_certificate'
  name           String
  content_json   Json     @default("{}")
  is_default     Boolean  @default(false)
  is_active      Boolean  @default(true)
  created_by     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, type, name])
  @@index([organizationId])
  @@map("document_templates")
}

model AlertRule {
  id             String   @id @default(uuid())
  organizationId String
  category       String // 'clinical', 'operational', 'financial', 'staff', 'patient', 'system'
  trigger_key    String // 'lab_critical_value', 'bed_occupancy_high', 'invoice_overdue', 'stock_low'
  name           String
  enabled        Boolean  @default(true)
  channels       Json     @default("[\"in_app\"]")
  recipients     Json     @default("{}")
  threshold      Json?
  escalation     Json?
  template       String?
  quiet_hours    Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("alert_rules")
}

// ========================================
// MODULE — Super Admin (Platform Owner)
// ========================================

model SuperAdmin {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@map("super_admins")
}

// ========================================
// MODULE — Users & Staff
// ========================================

model User {
  id                     String   @id @default(uuid())
  username               String   @unique
  password               String
  role                   String // admin, doctor, receptionist, lab_technician, pharmacist, finance, ipd_manager, nurse, opd_manager, hr
  name                   String?
  specialty              String?
  email                  String?
  phone                  String?
  assigned_ward_id       Int?
  doctor_registration_no String?
  qualifications         String?
  organizationId         String
  is_active              Boolean  @default(true)
  working_hours          String   @default("09:00-17:00")
  slot_duration          Int      @default(20)
  consultation_fee       Float    @default(500)
  follow_up_fee          Float    @default(300)
  createdAt              DateTime @default(now())

  organization      Organization      @relation(fields: [organizationId], references: [id])
  appointment_slots AppointmentSlot[]

  @@index([organizationId])
  @@map("users")
}

// ========================================
// MODULE — Registration & OPD
// ========================================

model OPD_REG {
  id                         Int       @id @default(autoincrement())
  patient_id                 String    @unique
  full_name                  String
  age                        String?
  gender                     String?
  phone                      String?
  email                      String?
  address                    String?
  department                 String?
  aadhar_card                String?
  emergency_contact_name     String?
  emergency_contact_phone    String?
  emergency_contact_relation String?
  blood_group                String?
  date_of_birth              String?
  registration_consent       Boolean   @default(false)
  profile_photo_url          String?
  allergies                  String?
  chronic_conditions         String?
  abha_number                String?
  abha_address               String?
  pan_number                 String?
  employee_id                String?
  registration_number        String?
  organizationId             String
  password                   String?
  is_archived                Boolean   @default(false)
  archived_at                DateTime?
  created_at                 DateTime  @default(now())

  // Phase 1 — Patient Type Classification
  patient_type          String  @default("cash") // cash | corporate | tpa_insurance
  corporate_id          String?
  corporate_card_number String?

  organization          Organization                @relation(fields: [organizationId], references: [id])
  corporate             CorporateMaster?            @relation(fields: [corporate_id], references: [id])
  appointments          appointments[]
  admissions            admissions[]
  invoices              invoices[]
  insurance_policies    insurance_policies[]
  feedbacks             PatientFeedback[]
  password_setup_tokens PatientPasswordSetupToken[]
  pill_reminders        PillReminder[]
  video_call_requests   VideoCallRequest[]
  whatsapp_logs         whatsapp_log[]
  pre_authorizations    PreAuthorization[]
  // Phase 3 — EMR
  clinical_encounters   ClinicalEncounter[]
  patient_allergies     PatientAllergy[]

  @@index([organizationId])
  @@index([organizationId, is_archived])
  @@index([created_at])
  @@index([organizationId, created_at])
  @@index([patient_type])
}

model appointments {
  id                  Int       @id @default(autoincrement())
  appointment_id      String    @unique
  patient_id          String
  doctor_name         String?
  doctor_id           String?
  department          String?
  status              String    @default("Pending")
  reason_for_visit    String?
  cancellation_reason String?
  follow_up_date      DateTime?
  organizationId      String
  queue_token         Int?
  checked_in_at       DateTime?
  called_at           DateTime?
  appointment_date    DateTime  @default(now())
  reminder24Sent      Boolean   @default(false)
  slot_id             String?   @unique

  organization Organization @relation(fields: [organizationId], references: [id])
  patient      OPD_REG      @relation(fields: [patient_id], references: [patient_id])

  @@index([organizationId])
  @@index([status])
  @@index([patient_id])
  @@index([appointment_date])
  @@index([doctor_id])
}

// ========================================
// MODULE — Clinical & Doctor
// ========================================

model Clinical_EHR {
  appointment_id String    @id
  patient_id     String
  doctor_name    String?
  diagnosis      String?
  doctor_notes   String?
  organizationId String
  is_archived    Boolean   @default(false)
  archived_at    DateTime?
  created_at     DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, is_archived])
}

model VideoCallRequest {
  id               String    @id @default(uuid())
  patient_id       String
  doctor_id        String
  request_date     DateTime  @default(now())
  status           String    @default("Pending") // Pending, Accepted, Rejected, Completed
  scheduled_at     DateTime?
  meet_link        String?
  reason           String?
  rejection_reason String?
  organizationId   String

  organization Organization @relation(fields: [organizationId], references: [id])
  patient      OPD_REG      @relation(fields: [patient_id], references: [patient_id])

  @@index([organizationId])
  @@index([patient_id])
  @@index([doctor_id])
  @@map("video_call_requests")
}

// ========================================
// MODULE — Laboratory
// ========================================

model lab_orders {
  id                     Int       @id @default(autoincrement())
  barcode                String    @unique
  patient_id             String
  doctor_id              String
  test_type              String
  status                 String
  result_value           String?
  technician_remarks     String?
  report_url             String?
  assigned_technician_id String?
  is_critical            Boolean   @default(false)
  critical_notified_at   DateTime?
  organizationId         String
  is_archived            Boolean   @default(false)
  archived_at            DateTime?
  created_at             DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([patient_id])
  @@index([created_at])
  @@index([organizationId, is_archived])
}

model lab_test_inventory {
  id               Int     @id @default(autoincrement())
  test_name        String  @unique
  price            Float
  is_available     Boolean @default(true)
  normal_range_min Float?
  normal_range_max Float?
  unit             String?
  category         String?
  sample_type      String?
  hsn_sac_code     String?
  tax_rate         Float?  @default(0)
  organizationId   String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model lab_staff {
  id             Int     @id @default(autoincrement())
  name           String
  role           String
  is_on_shift    Boolean @default(false)
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model lab_audit_logs {
  id             Int      @id @default(autoincrement())
  action_type    String
  barcode        String
  details        String?
  organizationId String?
  created_at     DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ========================================
// MODULE — Pharmacy
// ========================================

model pharmacy_medicine_master {
  id             Int     @id @default(autoincrement())
  brand_name     String  @unique
  generic_name   String?
  category       String?
  manufacturer   String?
  // legacy field retained for backward compat; mirrors selling_price
  price_per_unit Float
  // NEW pricing fields
  mrp            Float   @default(0)
  purchase_price Float   @default(0)
  selling_price  Float   @default(0)
  gst_percent    Float   @default(0)
  // formulation metadata
  strength       String?
  form           String? // tablet, syrup, injection, etc.
  min_threshold  Int     @default(10)
  hsn_sac_code   String?
  tax_rate       Float?  @default(0) // keep for existing GST calc — sync with gst_percent on save
  is_active      Boolean @default(true)
  organizationId String

  organization Organization               @relation(fields: [organizationId], references: [id])
  batches      pharmacy_batch_inventory[]

  @@index([organizationId])
}

model pharmacy_batch_inventory {
  id               Int       @id @default(autoincrement())
  medicine_id      Int
  batch_no         String    @unique
  current_stock    Int
  manufacture_date DateTime?
  expiry_date      DateTime
  cost_price       Float? // purchase price at the time this batch was received
  rack_location    String?
  supplier_name    String?

  medicine pharmacy_medicine_master @relation(fields: [medicine_id], references: [id])
}

model pharmacy_sales_audit {
  id             Int      @id @default(autoincrement())
  action_type    String
  medicine_name  String?
  batch_no       String?
  quantity_sold  Int
  details        String?
  organizationId String?
  created_at     DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model pharmacy_orders {
  id                    Int      @id @default(autoincrement())
  patient_id            String
  doctor_id             String
  total_amount          Float    @default(0.0)
  status                String   @default("Pending")
  total_items_requested Int?
  items_dispensed       Int?
  items_missing         Int?
  organizationId        String
  admission_id          String?
  is_ipd_linked         Boolean  @default(false)
  created_at            DateTime @default(now())

  organization Organization           @relation(fields: [organizationId], references: [id])
  items        pharmacy_order_items[]

  @@index([organizationId])
}

model pharmacy_order_items {
  id                 Int     @id @default(autoincrement())
  order_id           Int
  medicine_name      String
  quantity_requested Int
  quantity_dispensed Int?
  unit_price         Float?
  total_price        Float?
  batch_id           String?
  status             String  @default("Pending")

  order pharmacy_orders @relation(fields: [order_id], references: [id])
}

// ========================================
// MODULE — In-Patient & Discharge
// ========================================

model admissions {
  admission_id              String    @id @default(uuid())
  patient_id                String
  bed_id                    String?
  ward_id                   Int?
  status                    String // Admitted, Discharged
  diagnosis                 String?
  doctor_name               String?
  line_of_treatment         String?
  admission_type            String?
  surgery_requested         String?
  is_death                  Boolean   @default(false)
  case_fir_number           String?
  case_is_rta               Boolean   @default(false)
  case_is_substance_abuse   Boolean   @default(false)
  case_is_police_report     Boolean   @default(false)
  case_is_test_conducted    Boolean   @default(false)
  case_injury_date          DateTime?
  past_ailments             String?
  past_ailment_duration     String?
  other_ailments            String?
  consent_signature_url     String?
  id_cards_url              String?
  organizationId            String
  is_archived               Boolean   @default(false)
  archived_at               DateTime?
  admission_date            DateTime  @default(now())
  discharge_date            DateTime?
  // IPD Upgrade fields
  admission_category        String? // Planned, Emergency, DayCare, Observation
  expected_discharge_date   DateTime?
  fit_for_discharge_at      DateTime?
  fit_for_discharge_by      String?
  discharge_checklist       Json?
  fall_risk_score           Int?
  pressure_ulcer_risk       Int?
  code_status               String? // Full, DNR, DNI, ComfortOnly
  news_score_latest         Int?
  attending_doctor_id       String? // FK to doctor user
  admission_source          String? // OPD | Emergency | Transfer | DirectAdmit
  discharge_type            String? // Normal | LAMA | DAMA | Absconded | Death | Transfer
  discharge_disposition     String? // home, SNF, rehab, etc.
  patient_class             String? // General | SemiPrivate | Private | Suite | ICU | NICU | PICU
  primary_diagnosis_icd     String? // ICD-10 code
  secondary_diagnoses       Json? // array of ICD-10 codes
  isolation_type            String? // None | Contact | Droplet | Airborne | Reverse
  medication_reconciliation Json? // discharge meds reconciliation
  discharge_instructions    String? // patient instructions
  allergy_alerts            Json? // pulled from patient master
  version                   Int       @default(0)

  organization           Organization           @relation(fields: [organizationId], references: [id])
  patient                OPD_REG                @relation(fields: [patient_id], references: [patient_id])
  bed                    beds?                  @relation(fields: [bed_id], references: [bed_id])
  ward                   wards?                 @relation(fields: [ward_id], references: [ward_id])
  medical_notes          medical_notes[]
  summaries              discharge_summaries[]
  invoices               invoices[]
  insurance_claims       insurance_claims[]
  bed_transfers          BedTransfer[]
  diet_plans             DietPlan[]
  ward_rounds            WardRound[]
  nursing_tasks          NursingTask[]
  ipd_admission_packages IpdAdmissionPackage[]
  ipd_vitals             IPDVitals[]
  nursing_assessments    NursingAssessment[]
  admission_consultants  AdmissionConsultant[]
  // Finance: GST Compliance
  gst_invoice_register   GST_Invoice_Register[]
  gst_return_filings     GST_Return_Filing[]
  hsn_sac_master         HSN_SAC_Master[]
  // Finance: General Ledger & Tally Integration
  gl_accounts            GL_Account[]
  gl_journal_entries     GL_JournalEntry[]
  gl_journal_lines       GL_JournalLine[]
  tally_exports          TallyExport[]
  insurance_preauths     InsurancePreAuth[]

  @@index([organizationId])
  @@index([status])
  @@index([patient_id])
  @@index([admission_date])
  @@index([organizationId, is_archived])
}

model medical_notes {
  id             Int      @id @default(autoincrement())
  admission_id   String
  note_type      String
  details        String
  organizationId String
  created_at     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  admission    admissions   @relation(fields: [admission_id], references: [admission_id])

  @@index([organizationId])
}

model discharge_summaries {
  id                Int      @id @default(autoincrement())
  admission_id      String
  patient_name      String?
  generated_summary String
  organizationId    String
  created_at        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  admission    admissions   @relation(fields: [admission_id], references: [admission_id])

  @@index([organizationId])
}

// ========================================
// MODULE — Bed & Ward Management
// ========================================

model beds {
  bed_id                String       @id
  ward_id               Int?
  status                String?      @default("Available")
  bed_category          String?
  pricing_tier          String?
  organizationId        String
  // IPD Upgrade fields
  is_isolation          Boolean      @default(false)
  cleaning_started_at   DateTime?
  cleaning_completed_at DateTime?
  last_occupied_by      String?
  admissions            admissions[]

  organization Organization @relation(fields: [organizationId], references: [id])
  wards        wards?       @relation(fields: [ward_id], references: [ward_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([organizationId])
  @@index([organizationId, status])
}

model wards {
  ward_id        Int          @id @default(autoincrement())
  ward_name      String
  ward_type      String
  cost_per_day   Decimal?     @default(0)
  nursing_charge Decimal?     @default(0)
  department_id  String?
  floor_number   String?
  is_active      Boolean      @default(true)
  organizationId String
  beds           beds[]
  admissions     admissions[]

  organization Organization @relation(fields: [organizationId], references: [id])
  department   Department?  @relation(fields: [department_id], references: [id])

  @@index([organizationId])
}

// ========================================
// MODULE — Finance & Billing Engine
// ========================================

model invoices {
  id             Int       @id @default(autoincrement())
  invoice_number String    @unique
  patient_id     String
  admission_id   String?
  invoice_type   String    @default("OPD")
  total_amount   Decimal   @default(0)
  total_discount Decimal   @default(0)
  net_amount     Decimal   @default(0)
  paid_amount    Decimal   @default(0)
  balance_due    Decimal   @default(0)
  status         String    @default("Draft")
  notes          String?
  organizationId String
  is_archived    Boolean   @default(false)
  archived_at    DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  finalized_at   DateTime?
  total_tax      Decimal   @default(0)
  cgst_amount    Decimal   @default(0)
  sgst_amount    Decimal   @default(0)
  igst_amount    Decimal   @default(0)
  is_inter_state Boolean   @default(false)
  estimate_id    Int?
  approved_by    String?
  approved_at    DateTime?

  // Phase 2 — Billing Engine (patient type split)
  billing_patient_type     String  @default("cash") // cash | corporate | tpa_insurance
  corporate_id             String?
  tpa_provider_id          Int?
  pre_auth_id              String?
  patient_payable          Decimal @default(0)
  corporate_payable        Decimal @default(0)
  tpa_payable              Decimal @default(0)
  tpa_claim_status         String  @default("not_submitted") // not_submitted | submitted | under_review | approved | rejected | settled | partially_settled
  tpa_claim_number         String?
  tpa_settled_amount       Decimal @default(0)
  corporate_invoice_number String?
  concession_amount        Decimal @default(0)
  concession_reason        String?
  concession_approved_by   String?

  organization          Organization         @relation(fields: [organizationId], references: [id])
  patient               OPD_REG              @relation(fields: [patient_id], references: [patient_id])
  admission             admissions?          @relation(fields: [admission_id], references: [admission_id])
  items                 invoice_items[]
  payments              payments[]
  payment_order_intents PaymentOrderIntent[]
  insurance_claims      insurance_claims[]
  credit_notes          CreditNote[]
  payment_splits        PaymentSplit[]

  @@index([organizationId])
  @@index([status])
  @@index([patient_id])
  @@index([billing_patient_type])
  @@index([created_at])
  @@index([organizationId, is_archived])
}

model invoice_items {
  id               Int      @id @default(autoincrement())
  invoice_id       Int
  department       String
  description      String
  quantity         Int      @default(1)
  unit_price       Decimal
  total_price      Decimal
  discount         Decimal  @default(0)
  net_price        Decimal
  ref_id           String?
  tax_rate         Decimal  @default(0)
  tax_amount       Decimal  @default(0)
  hsn_sac_code     String?
  service_category String?
  organizationId   String
  created_at       DateTime @default(now())

  invoice      invoices     @relation(fields: [invoice_id], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([invoice_id])
  @@index([organizationId])
  @@index([department])
}

model payments {
  id                   Int      @id @default(autoincrement())
  receipt_number       String   @unique
  invoice_id           Int
  amount               Decimal
  payment_method       String
  payment_type         String
  razorpay_order_id    String?
  razorpay_payment_id  String?
  transaction_group_id String?
  reference            String?
  status               String   @default("Completed")
  notes                String?
  organizationId       String
  created_at           DateTime @default(now())

  invoice      invoices     @relation(fields: [invoice_id], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([invoice_id])
  @@index([organizationId])
  @@index([status])
  @@index([transaction_group_id])
}

model PaymentOrderIntent {
  id                String    @id @default(uuid())
  razorpay_order_id String    @unique
  invoice_id        Int
  expected_amount   Decimal
  status            String    @default("created") // created, verified, expired
  organizationId    String
  created_by        String?
  created_at        DateTime  @default(now())
  expires_at        DateTime
  verified_at       DateTime?

  invoice      invoices     @relation(fields: [invoice_id], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, invoice_id])
  @@index([status, expires_at])
  @@map("payment_order_intents")
}

model charge_catalog {
  id               Int      @id @default(autoincrement())
  category         String
  item_code        String   @unique
  item_name        String
  default_price    Decimal
  department       String?
  hsn_sac_code     String?
  tax_rate         Decimal?
  service_category String?
  is_active        Boolean  @default(true)
  organizationId   String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ========================================
// MODULE — Insurance & TPA
// ========================================

model insurance_providers {
  id             Int      @id @default(autoincrement())
  provider_name  String   @unique
  provider_code  String   @unique
  contact_email  String?
  contact_phone  String?
  contact_person String?
  address        String?
  is_active      Boolean  @default(true)
  organizationId String
  created_at     DateTime @default(now())

  // Phase 1 — TPA/Insurance extended fields
  tpa_type                    String? // tpa | insurance_direct
  pre_auth_required           Boolean @default(true)
  claim_submission_mode       String  @default("online") // online | manual | mixed
  default_discount_percentage Decimal @default(0)
  payment_terms_days          Int     @default(45)
  covered_services            Json    @default("[]")
  excluded_services           Json    @default("[]")

  organization       Organization         @relation(fields: [organizationId], references: [id])
  policies           insurance_policies[]
  pre_authorizations PreAuthorization[]

  @@index([organizationId])
}

model insurance_policies {
  id              Int       @id @default(autoincrement())
  patient_id      String
  provider_id     Int
  policy_number   String    @unique
  policy_holder   String?
  plan_name       String?
  member_id       String?
  policy_type     String?
  corporate_name  String?
  insurer_id      String?
  payer_id        String?
  coverage_limit  Decimal?
  remaining_limit Decimal?
  valid_from      DateTime?
  valid_until     DateTime?
  status          String    @default("Active")
  organizationId  String
  created_at      DateTime  @default(now())

  organization Organization        @relation(fields: [organizationId], references: [id])
  patient      OPD_REG             @relation(fields: [patient_id], references: [patient_id])
  provider     insurance_providers @relation(fields: [provider_id], references: [id])
  claims       insurance_claims[]

  @@index([organizationId])
}

model insurance_claims {
  id                    Int       @id @default(autoincrement())
  claim_number          String    @unique
  policy_id             Int
  invoice_id            Int
  admission_id          String?
  claimed_amount        Decimal
  approved_amount       Decimal?
  rejected_amount       Decimal?
  status                String    @default("Submitted")
  rejection_reason      String?
  zealthix_claim_number String?
  action_status         String?
  settled_amount        Decimal?
  tds_amount            Decimal?
  zealthix_remarks      String?
  zealthix_attachments  Json?
  organizationId        String
  submitted_at          DateTime  @default(now())
  reviewed_at           DateTime?
  settled_at            DateTime?

  organization Organization       @relation(fields: [organizationId], references: [id])
  policy       insurance_policies @relation(fields: [policy_id], references: [id])
  invoice      invoices           @relation(fields: [invoice_id], references: [id])
  admission    admissions?        @relation(fields: [admission_id], references: [admission_id])

  @@index([organizationId])
}

// ========================================
// MODULE — EMR / Clinical (Phase 3)
// ========================================

model ClinicalEncounter {
  id             String   @id @default(uuid())
  organizationId String
  patient_id     String
  appointment_id String?
  doctor_id      String
  encounter_date DateTime @default(now())

  // SOAP structured as JSON
  subjective Json @default("{}")
  // { chief_complaint, hpi, ros, social_history, family_history }
  objective  Json @default("{}")
  // { vitals, physical_exam, observations }
  assessment Json @default("[]")
  // [{ diagnosis_text, icd10_code, icd10_description, type, status }]
  plan       Json @default("{}")
  // { medications, lab_orders, procedures, referrals, follow_up, instructions }

  allergies_reviewed Boolean   @default(false)
  status             String    @default("in_progress") // in_progress | completed | amended
  signed_at          DateTime?
  signed_by          String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  patient      OPD_REG      @relation(fields: [patient_id], references: [patient_id])

  @@index([organizationId])
  @@index([patient_id])
  @@index([doctor_id])
  @@map("clinical_encounters")
}

model PatientAllergy {
  id             String   @id @default(uuid())
  organizationId String
  patient_id     String
  allergen_name  String
  allergen_type  String   @default("drug") // drug | food | environmental | other
  reaction       String?
  severity       String   @default("moderate") // mild | moderate | severe | life_threatening
  status         String   @default("active") // active | inactive | resolved
  reported_date  DateTime @default(now())
  created_at     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  patient      OPD_REG      @relation(fields: [patient_id], references: [patient_id])

  @@index([organizationId])
  @@index([patient_id])
  @@index([allergen_type])
  @@map("patient_allergies")
}

// ========================================
// MODULE — Payment Splits (Phase 2)
// ========================================

model PaymentSplit {
  id                String   @id @default(uuid())
  organizationId    String
  invoice_id        Int
  payer_type        String // patient | corporate | tpa_insurance
  payer_id          String? // corporate_id or tpa_provider_id (as string) or null for patient
  amount            Decimal
  payment_method    String? // cash | upi | card | bank_transfer | cheque
  payment_reference String?
  payment_date      DateTime @default(now())
  received_by       String?
  status            String   @default("received") // pending | received | bounced | refunded
  created_at        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  invoice      invoices     @relation(fields: [invoice_id], references: [id])

  @@index([organizationId])
  @@index([invoice_id])
  @@map("payment_splits")
}

// ========================================
// MODULE — Corporate & Pre-Authorization (Phase 1)
// ========================================

model CorporateMaster {
  id                  String    @id @default(uuid())
  organizationId      String
  company_name        String
  company_code        String
  contact_person      String?
  contact_phone       String?
  contact_email       String?
  credit_limit        Decimal   @default(0)
  current_balance     Decimal   @default(0)
  discount_percentage Decimal   @default(0)
  payment_terms_days  Int       @default(30)
  contract_start      DateTime?
  contract_end        DateTime?
  is_active           Boolean   @default(true)
  covered_services    Json      @default("[]")
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id])
  patients           OPD_REG[]
  pre_authorizations PreAuthorization[]

  @@unique([organizationId, company_code])
  @@index([organizationId])
  @@map("corporate_masters")
}

model PreAuthorization {
  id               String    @id @default(uuid())
  organizationId   String
  patient_id       String
  provider_id      Int?
  corporate_id     String?
  appointment_id   String?
  pre_auth_number  String?
  requested_amount Decimal?
  approved_amount  Decimal?
  status           String    @default("pending") // pending | approved | rejected | expired | partially_approved
  requested_at     DateTime  @default(now())
  responded_at     DateTime?
  valid_until      DateTime?
  remarks          String?
  documents        Json      @default("[]")
  created_at       DateTime  @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id])
  patient      OPD_REG              @relation(fields: [patient_id], references: [patient_id])
  provider     insurance_providers? @relation(fields: [provider_id], references: [id])
  corporate    CorporateMaster?     @relation(fields: [corporate_id], references: [id])

  @@index([organizationId])
  @@index([patient_id])
  @@index([status])
  @@map("pre_authorizations")
}

// ========================================
// MODULE — Legacy Billing
// ========================================

model billing_records {
  id                 Int      @id @default(autoincrement())
  patient_id         String
  patient_name       String?
  bill_type          String
  department         String?
  description        String?
  amount             Float
  discount           Float    @default(0)
  net_amount         Float
  payment_status     String   @default("Pending")
  payment_method     String?
  insurance_claim_id String?
  organizationId     String
  created_at         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([payment_status])
  @@index([created_at])
  @@index([payment_status, created_at])
}

// ========================================
// MODULE — System Audit Trail
// ========================================

model system_audit_logs {
  id             Int      @id @default(autoincrement())
  user_id        String?
  username       String?
  role           String?
  action         String
  module         String
  entity_type    String?
  entity_id      String?
  details        String?
  ip_address     String?
  organizationId String?
  created_at     DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([action])
  @@index([module])
  @@index([created_at])
}

// ========================================
// MODULE — AI Triage & Vitals
// ========================================

model triage_results {
  id                     Int      @id @default(autoincrement())
  patient_id             String?
  patient_name           String?
  symptoms               String
  duration               String?
  severity               String?
  past_medical_history   String?
  current_medications    String?
