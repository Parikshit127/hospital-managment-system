// ========================================
// MODULE — Finance: General Ledger & Tally Integration
// ========================================

model GL_Account {
  id                String   @id @default(uuid())
  organizationId    String
  account_code      String
  account_name      String
  account_type      String // Asset, Liability, Equity, Revenue, Expense
  account_group     String? // Group for reporting (e.g., Current Assets, Fixed Assets)
  parent_id         String?
  normal_balance    String // Debit, Credit
  opening_balance   Decimal  @default(0) @db.Decimal(15, 2)
  current_balance   Decimal  @default(0) @db.Decimal(15, 2)
  tally_ledger_name String?
  tally_group       String?
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  organization           Organization     @relation(fields: [organizationId], references: [id])
  parent                 GL_Account?      @relation("AccountHierarchy", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children               GL_Account[]     @relation("AccountHierarchy")
  journal_lines          GL_JournalLine[]
  asset_categories_as_asset_account       AssetCategory[] @relation("AssetAccount")
  asset_categories_as_depreciation_account AssetCategory[] @relation("DepreciationAccount")
  asset_categories_as_expense_account     AssetCategory[] @relation("ExpenseAccount")
  budget_lines                             BudgetLine[]
  admissions             admissions?      @relation(fields: [admissionsAdmission_id], references: [admission_id])
  admissionsAdmission_id String?

  @@unique([account_code, organizationId])
  @@index([organizationId])
  @@index([parent_id])
  @@index([account_type])
  @@map("gl_accounts")
}

model GL_JournalEntry {
  id                String   @id @default(uuid())
  organizationId    String
  journal_number    String // Auto-generated: JV-YYYY-NNNN
  entry_date        DateTime
  period_id         Int?
  entry_type        String // Manual, Invoice, Payment, Expense, Adjustment, Opening, Closing, Depreciation
  reference_type    String? // Invoice, Payment, Expense, Deposit, Refund, Asset, etc.
  reference_id      String?
  reference_number  String?
  narration         String
  total_debit       Decimal  @db.Decimal(15, 2)
  total_credit      Decimal  @db.Decimal(15, 2)
  status            String   @default("Draft") // Draft, Posted, Reversed
  reversal_entry_id String?  @unique
  created_by        String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  organization           Organization     @relation(fields: [organizationId], references: [id])
  period                 FinancialPeriod? @relation(fields: [period_id], references: [id])
  reversal_entry         GL_JournalEntry? @relation("JournalReversal", fields: [reversal_entry_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reversed_by            GL_JournalEntry? @relation("JournalReversal")
  lines                  GL_JournalLine[]
  depreciation_entries   DepreciationEntry[]
  admissions             admissions?      @relation(fields: [admissionsAdmission_id], references: [admission_id])
  admissionsAdmission_id String?

  @@unique([journal_number, organizationId])
  @@index([organizationId])
  @@index([period_id])
  @@index([entry_date])
  @@index([entry_type])
  @@index([reference_type, reference_id])
  @@map("gl_journal_entries")
}

model GL_JournalLine {
  id             String   @id @default(uuid())
  organizationId String
  journal_id     String
  line_number    Int
  account_id     String
  debit_amount   Decimal  @default(0) @db.Decimal(15, 2)
  credit_amount  Decimal  @default(0) @db.Decimal(15, 2)
  description    String?
  cost_center    String?
  created_at     DateTime @default(now())

  organization           Organization    @relation(fields: [organizationId], references: [id])
  journal                GL_JournalEntry @relation(fields: [journal_id], references: [id], onDelete: Cascade)
  account                GL_Account      @relation(fields: [account_id], references: [id])
  admissions             admissions?     @relation(fields: [admissionsAdmission_id], references: [admission_id])
  admissionsAdmission_id String?

  @@index([organizationId])
  @@index([journal_id])
  @@index([account_id])
  @@map("gl_journal_lines")
}

model TallyExport {
  id             String    @id @default(uuid())
  organizationId String
  export_number  String // Auto-generated: TALLY-YYYY-NNNN
  export_type    String // Vouchers, Ledgers, Masters, Full
  export_format  String    @default("XML") // XML, JSON
  start_date     DateTime?
  end_date       DateTime?
  file_path      String?
  file_size      BigInt?
  record_count   Int       @default(0)
  status         String    @default("Pending") // Pending, Processing, Completed, Failed
  error_message  String?
  created_by     String?
  created_at     DateTime  @default(now())
  completed_at   DateTime?

  organization           Organization @relation(fields: [organizationId], references: [id])
  admissions             admissions?  @relation(fields: [admissionsAdmission_id], references: [admission_id])
  admissionsAdmission_id String?

  @@unique([export_number, organizationId])
  @@index([organizationId])
  @@index([status])
  @@index([created_at])
  @@map("tally_exports")
}

// ========================================
// MODULE — Finance: GST Compliance
// ========================================

model GST_Invoice_Register {
  id                  String   @id @default(uuid())
  organizationId      String
  invoice_id          String?
  expense_id          String?
  transaction_type    String // Outward, Inward
  invoice_number      String
  invoice_date        DateTime
  gstin_supplier      String?
  gstin_recipient     String?
  recipient_name      String?
  recipient_state     String?
  place_of_supply     String?
  is_inter_state      Boolean  @default(false)
  reverse_charge      Boolean  @default(false)
  invoice_type        String   @default("Regular") // Regular, Export, SEZ
  taxable_amount      Decimal  @db.Decimal(15, 2)
  cgst_amount         Decimal  @default(0) @db.Decimal(15, 2)
  sgst_amount         Decimal  @default(0) @db.Decimal(15, 2)
  igst_amount         Decimal  @default(0) @db.Decimal(15, 2)
  cess_amount         Decimal  @default(0) @db.Decimal(15, 2)
  total_tax           Decimal  @db.Decimal(15, 2)
  total_invoice_value Decimal  @db.Decimal(15, 2)
  hsn_sac_code        String?
  gst_rate            Decimal? @db.Decimal(5, 2)
  itc_eligibility     String? // Eligible, Ineligible, Partial
  itc_claimed_cgst    Decimal  @default(0) @db.Decimal(15, 2)
  itc_claimed_sgst    Decimal  @default(0) @db.Decimal(15, 2)
  itc_claimed_igst    Decimal  @default(0) @db.Decimal(15, 2)
  filed_in_gstr1      Boolean  @default(false)
  filed_in_gstr2      Boolean  @default(false)
  filing_period       String? // MMYYYY
  created_at          DateTime @default(now())

  organization           Organization @relation(fields: [organizationId], references: [id])
  admissions             admissions?  @relation(fields: [admissionsAdmission_id], references: [admission_id])
  admissionsAdmission_id String?

  @@index([organizationId])
  @@index([invoice_date])
  @@index([transaction_type])
  @@index([filing_period])
  @@map("gst_invoice_register")
}

model GST_Return_Filing {
  id                  String    @id @default(uuid())
  organizationId      String
  return_type         String // GSTR1, GSTR2, GSTR3B
  filing_period       String // MMYYYY
  return_period_start DateTime
  return_period_end   DateTime
  status              String    @default("Draft") // Draft, Filed, Revised
  filed_date          DateTime?
  acknowledgment_no   String?

  // GSTR-1 Summary
  total_outward_supplies Decimal? @db.Decimal(15, 2)
  total_taxable_value    Decimal? @db.Decimal(15, 2)
  total_cgst             Decimal? @db.Decimal(15, 2)
  total_sgst             Decimal? @db.Decimal(15, 2)
  total_igst             Decimal? @db.Decimal(15, 2)

  // GSTR-3B Summary
  outward_taxable_supplies Decimal? @db.Decimal(15, 2)
  outward_tax_liability    Decimal? @db.Decimal(15, 2)
  itc_available            Decimal? @db.Decimal(15, 2)
  itc_reversed             Decimal? @db.Decimal(15, 2)
  net_tax_payable          Decimal? @db.Decimal(15, 2)
  interest                 Decimal? @db.Decimal(15, 2)
  late_fee                 Decimal? @db.Decimal(15, 2)

  json_data  String?  @db.Text // Full return JSON
  file_path  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization           Organization @relation(fields: [organizationId], references: [id])
  admissions             admissions?  @relation(fields: [admissionsAdmission_id], references: [admission_id])
  admissionsAdmission_id String?

  @@unique([return_type, filing_period, organizationId])
  @@index([organizationId])
  @@index([filing_period])
  @@map("gst_return_filings")
}

model HSN_SAC_Master {
  id             String  @id @default(uuid())
  organizationId String
  code           String
  description    String
  code_type      String // HSN, SAC
  uqc            String? // Unit of Quantity Code
  gst_rate       Decimal @db.Decimal(5, 2)
  is_active      Boolean @default(true)

  organization           Organization @relation(fields: [organizationId], references: [id])
  admissions             admissions?  @relation(fields: [admissionsAdmission_id], references: [admission_id])
  admissionsAdmission_id String?

  @@unique([code, organizationId])
  @@index([organizationId])
  @@map("hsn_sac_master")
}

// ============================================
// FIXED ASSET MANAGEMENT MODELS (Phase 3)
// ============================================

model AssetCategory {
  id                         String   @id @default(uuid())
  organizationId             String
  category_name              String
  category_code              String
  asset_type                 String   // Tangible, Intangible
  depreciation_method        String   // SLM, WDV
  depreciation_rate          Decimal  @db.Decimal(5, 2) // % per annum
  useful_life_years          Int?
  gl_asset_account_id        String?
  gl_depreciation_account_id String?
  gl_expense_account_id      String?
  is_active                  Boolean  @default(true)
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  organization           Organization  @relation(fields: [organizationId], references: [id])
  gl_asset_account       GL_Account?   @relation("AssetAccount", fields: [gl_asset_account_id], references: [id])
  gl_depreciation_account GL_Account? @relation("DepreciationAccount", fields: [gl_depreciation_account_id], references: [id])
  gl_expense_account     GL_Account?   @relation("ExpenseAccount", fields: [gl_expense_account_id], references: [id])
  assets                 FixedAsset[]

  @@unique([category_code, organizationId])
  @@index([organizationId])
  @@map("asset_categories")
}

model FixedAsset {
  id                      String    @id @default(uuid())
  organizationId          String
  asset_code              String
  asset_name              String
  category_id             String
  description             String?   @db.Text
  location                String?
  department              String?

  // Acquisition
  acquisition_date        DateTime
  acquisition_cost        Decimal   @db.Decimal(15, 2)
  vendor_id               Int?
  invoice_number          String?
  warranty_expiry         DateTime?

  // Depreciation
  depreciation_method     String    // SLM, WDV
  depreciation_rate       Decimal   @db.Decimal(5, 2)
  salvage_value           Decimal   @default(0) @db.Decimal(15, 2)
  accumulated_depreciation Decimal  @default(0) @db.Decimal(15, 2)
  book_value              Decimal   @db.Decimal(15, 2)
  last_depreciation_date  DateTime?

  // Status
  status                  String    @default("Active") // Active, Disposed, Sold, WrittenOff, UnderMaintenance
  disposed_date           DateTime?
  disposal_value          Decimal?  @db.Decimal(15, 2)
  disposal_reason         String?   @db.Text

  // Maintenance
  maintenance_schedule    String?   // Monthly, Quarterly, Yearly
  last_maintenance_date   DateTime?
  next_maintenance_date   DateTime?

  // Additional
  serial_number           String?
  manufacturer            String?
  model_number            String?
  is_capitalized          Boolean   @default(true)
  capitalization_date     DateTime?

  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  organization       Organization         @relation(fields: [organizationId], references: [id])
  category           AssetCategory        @relation(fields: [category_id], references: [id])
  vendor             Vendor?              @relation(fields: [vendor_id], references: [id])
  depreciation_entries DepreciationEntry[]
  transfers          AssetTransfer[]
  maintenance_records AssetMaintenance[]

  @@unique([asset_code, organizationId])
  @@index([organizationId])
  @@index([category_id])
  @@index([status])
  @@map("fixed_assets")
}

model DepreciationEntry {
  id                      String    @id @default(uuid())
  organizationId          String
  asset_id                String
  depreciation_period     String    // MMYYYY
  period_start            DateTime
  period_end              DateTime
  opening_book_value      Decimal   @db.Decimal(15, 2)
  depreciation_amount     Decimal   @db.Decimal(15, 2)
  accumulated_depreciation Decimal  @db.Decimal(15, 2)
  closing_book_value      Decimal   @db.Decimal(15, 2)
  calculation_method      String    // SLM, WDV
  journal_entry_id        String?
  status                  String    @default("Draft") // Draft, Posted, Reversed
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  asset          FixedAsset      @relation(fields: [asset_id], references: [id])
  journal_entry  GL_JournalEntry? @relation(fields: [journal_entry_id], references: [id])

  @@unique([asset_id, depreciation_period])
  @@index([organizationId])
  @@index([depreciation_period])
  @@index([status])
  @@map("depreciation_entries")
}

model AssetTransfer {
  id               String   @id @default(uuid())
  organizationId   String
  asset_id         String
  from_location    String?
  to_location      String?
  from_department  String?
  to_department    String?
  transfer_date    DateTime
  transfer_reason  String?  @db.Text
  approved_by      String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  asset        FixedAsset   @relation(fields: [asset_id], references: [id])

  @@index([organizationId])
  @@index([asset_id])
  @@map("asset_transfers")
}

model AssetMaintenance {
  id                String    @id @default(uuid())
  organizationId    String
  asset_id          String
  maintenance_type  String    // Preventive, Corrective, Calibration
  maintenance_date  DateTime
  description       String?   @db.Text
  cost              Decimal?  @db.Decimal(15, 2)
  vendor_id         Int?
  next_due_date     DateTime?
  performed_by      String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  asset        FixedAsset   @relation(fields: [asset_id], references: [id])
  vendor       Vendor?      @relation(fields: [vendor_id], references: [id])

  @@index([organizationId])
  @@index([asset_id])
  @@index([next_due_date])
  @@map("asset_maintenance")
}

// ============================================
// BUDGET MANAGEMENT MODELS (Phase 4)
// ============================================

model BudgetMaster {
  id                  String    @id @default(uuid())
  organizationId      String
  budget_name         String
  budget_year         Int
  budget_period       String    // Annual, Quarterly, Monthly
  start_date          DateTime
  end_date            DateTime
  status              String    @default("Draft") // Draft, Approved, Active, Closed, Revised
  approved_by         String?
  approved_at         DateTime?
  total_budget        Decimal   @default(0) @db.Decimal(15, 2)
  total_actual        Decimal   @default(0) @db.Decimal(15, 2)
  total_variance      Decimal   @default(0) @db.Decimal(15, 2)
  variance_percentage Decimal   @default(0) @db.Decimal(5, 2)
  notes               String?   @db.Text
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  budget_lines BudgetLine[]
  revisions    BudgetRevision[]

  @@unique([budget_name, budget_year, organizationId])
  @@index([organizationId])
  @@index([budget_year])
  @@index([status])
  @@map("budget_masters")
}

model BudgetLine {
  id                  String   @id @default(uuid())
  organizationId      String
  budget_master_id    String
  department          String?
  cost_center         String?
  account_id          String?
  expense_category_id Int?
  line_description    String
  budget_amount       Decimal  @default(0) @db.Decimal(15, 2)
  actual_amount       Decimal  @default(0) @db.Decimal(15, 2)
  variance            Decimal  @default(0) @db.Decimal(15, 2)
  variance_percentage Decimal  @default(0) @db.Decimal(5, 2)
  alert_threshold     Decimal  @default(90) @db.Decimal(5, 2)
  is_locked           Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id])
  budget_master    BudgetMaster     @relation(fields: [budget_master_id], references: [id], onDelete: Cascade)
  gl_account       GL_Account?      @relation(fields: [account_id], references: [id])
  expense_category ExpenseCategory? @relation(fields: [expense_category_id], references: [id])
  alerts           BudgetAlert[]

  @@index([organizationId])
  @@index([budget_master_id])
  @@index([department])
  @@map("budget_lines")
}

model BudgetRevision {
  id               String    @id @default(uuid())
  organizationId   String
  budget_master_id String
  revision_number  Int
  revision_date    DateTime
  revised_by       String?
  reason           String    @db.Text
  previous_total   Decimal   @db.Decimal(15, 2)
  revised_total    Decimal   @db.Decimal(15, 2)
  variance         Decimal   @db.Decimal(15, 2)
  approved_by      String?
  approved_at      DateTime?
  status           String    @default("Pending") // Pending, Approved, Rejected
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id])
  budget_master BudgetMaster @relation(fields: [budget_master_id], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([budget_master_id])
  @@map("budget_revisions")
}

model BudgetAlert {
  id                  String    @id @default(uuid())
  organizationId      String
  budget_line_id      String
  alert_type          String    // Threshold, Overrun, Underutilization
  alert_date          DateTime
  budget_amount       Decimal   @db.Decimal(15, 2)
  actual_amount       Decimal   @db.Decimal(15, 2)
  percentage_consumed Decimal   @db.Decimal(5, 2)
  message             String
  is_acknowledged     Boolean   @default(false)
  acknowledged_by     String?
  acknowledged_at     DateTime?
  created_at          DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  budget_line  BudgetLine   @relation(fields: [budget_line_id], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([budget_line_id])
  @@index([is_acknowledged])
  @@map("budget_alerts")
}
