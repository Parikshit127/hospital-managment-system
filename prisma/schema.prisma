// MODULE — Phase 3: OPD Manager
// ========================================

model OPDConfig {
  id                      Int     @id @default(autoincrement())
  max_wait_minutes        Int     @default(30)
  escalation_threshold    Int     @default(45)
  max_patients_per_doctor Int     @default(30)
  organizationId          String
  created_at              DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("opd_configs")
}

// ========================================
// MODULE — Phase 3: HR Management
// ========================================

model Employee {
  id               Int       @id @default(autoincrement())
  user_id          String?
  employee_code    String    @unique
  name             String
  designation      String
  department_id    String?
  date_of_joining  DateTime
  salary_basic     Float     @default(0)
  is_active        Boolean   @default(true)
  phone            String?
  email            String?
  organizationId   String
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  attendances      Attendance[]
  leave_requests   LeaveRequest[]
  shift_assignments ShiftAssignment[]

  @@index([organizationId])
  @@map("employees")
}

model Attendance {
  id             Int       @id @default(autoincrement())
  employee_id    Int
  date           DateTime
  check_in       DateTime?
  check_out      DateTime?
  total_hours    Float?
  status         String    @default("Present") // Present, Absent, Half-Day, Leave, Holiday
  organizationId String
  created_at     DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employee_id], references: [id])

  @@index([organizationId])
  @@index([employee_id])
  @@index([date])
  @@map("attendances")
}

model LeaveType {
  id              Int      @id @default(autoincrement())
  name            String
  days_per_year   Int      @default(12)
  carry_forward   Boolean  @default(false)
  organizationId  String
  created_at      DateTime @default(now())

  organization   Organization   @relation(fields: [organizationId], references: [id])
  leave_requests LeaveRequest[]

  @@index([organizationId])
  @@map("leave_types")
}

model LeaveRequest {
  id              Int       @id @default(autoincrement())
  employee_id     Int
  leave_type_id   Int
  from_date       DateTime
  to_date         DateTime
  reason          String?
  status          String    @default("Pending") // Pending, Approved, Rejected, Cancelled
  approved_by     String?
  organizationId  String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employee_id], references: [id])
  leave_type   LeaveType    @relation(fields: [leave_type_id], references: [id])

  @@index([organizationId])
  @@index([employee_id])
  @@index([status])
  @@map("leave_requests")
}

model ShiftPattern {
  id             Int      @id @default(autoincrement())
  name           String
  start_time     String   // "08:00"
  end_time       String   // "16:00"
  organizationId String
  created_at     DateTime @default(now())

  organization    Organization      @relation(fields: [organizationId], references: [id])
  assignments     ShiftAssignment[]

  @@index([organizationId])
  @@map("shift_patterns")
}

model ShiftAssignment {
  id               Int      @id @default(autoincrement())
  employee_id      Int
  shift_pattern_id Int
  date             DateTime
  organizationId   String
  created_at       DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id])
  employee      Employee     @relation(fields: [employee_id], references: [id])
  shift_pattern ShiftPattern @relation(fields: [shift_pattern_id], references: [id])

  @@index([organizationId])
  @@index([employee_id])
  @@index([date])
  @@map("shift_assignments")
}

// ========================================
// PHASE 4 — NOTIFICATIONS
// ========================================

model Notification {
  id             Int      @id @default(autoincrement())
  user_id        String
  title          String
  body           String
  type           String   @default("info") // info, success, warning, critical
  is_read        Boolean  @default(false)
  link           String?
  organizationId String
  created_at     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([user_id])
  @@index([is_read])
  @@map("notifications")
}
