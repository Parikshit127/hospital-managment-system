{
  "name": "hospital",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "predev": "node scripts/check-deps-sync.js && prisma generate",
    "dev": "next dev",
    "dev:fresh": "npm run clean && npm install && npm run dev",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "setup": "npm install && prisma generate && npm run clean",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "lint:ci": "eslint --max-warnings=0 app/lib/env.ts app/lib/route-auth.ts app/lib/password-setup.ts app/lib/login-rate-limit.ts app/patient/setup-password",
    "typecheck": "tsc --noEmit",
    "check:prisma": "prisma validate",
    "check:deps": "node scripts/check-deps-sync.js",
    "db:migrate:prod": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:status": "prisma migrate status",
    "db:backup": "mkdir -p backups && pg_dump \"$DIRECT_URL\" --format=custom --no-owner --no-acl --file \"backups/hospitalos-$(date +%Y%m%d-%H%M%S).dump\"",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@prisma/client": "^6.9.0",
    "@react-pdf/renderer": "^4.3.2",
    "@sparticuz/chromium": "^143.0.4",
    "@supabase/supabase-js": "^2.95.3",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.1",
    "openai": "^6.22.0",
    "prisma": "^6.9.0",
    "puppeteer-core": "^23.1.1",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "speakeasy": "^2.0.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/speakeasy": "^2.0.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "puppeteer": "^24.43.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
