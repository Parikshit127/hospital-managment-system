# =============================================================================
# HospitalOS Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git
# =============================================================================

# ── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Pooled connection (port 6543) - used by the application
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) - used for Prisma migrations only
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ── Supabase (Realtime & Storage) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET="generate-with: openssl rand -base64 64"
# Optional separate encryption key for admin-managed integration credentials
CONFIG_ENCRYPTION_KEY="generate-with: openssl rand -base64 64"

# ── Application ────────────────────────────────────────────────────────────
APP_BASE_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
HOSPITAL_NAME="Your Hospital Name"
ORGANIZATION_ID="uuid-of-your-organization"

# ── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ── Payments (Razorpay) ───────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxx"

# ── AI Features (Optional) ────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ── WhatsApp (AiSensy) ────────────────────────────────────────────────────
COMBIRDS_BASE_URL="https://backend.aisensy.com/campaign/t1/api"
AISENSY_API_KEY="your-aisensy-api-key"
WHATSAPP_VERIFY_TOKEN="generate-a-random-webhook-token"

# ── AWS S3 (File Storage) ─────────────────────────────────────────────────
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="hospitalos-production-documents"
# If running on EC2 with an IAM role, leave these blank (auto-detected)
# If running locally or on Vercel, provide explicit credentials:
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="your-secret-key"

# ── Scheduled Jobs ────────────────────────────────────────────────────────
CRON_SECRET="generate-with: openssl rand -base64 32"
INTERNAL_VERIFY_TOKEN="generate-with: openssl rand -base64 32"

# ── Seeding (Development Only) ────────────────────────────────────────────
# ALLOW_SEED="true"
# SEED_ADMIN_PASSWORD="change-me"
# SEED_SUPERADMIN_PASSWORD="change-me"
