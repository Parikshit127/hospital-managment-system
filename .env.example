# ==============================================
# Hospital OS — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env to git.

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Authentication — REQUIRED
# Generate with: openssl rand -base64 32
JWT_SECRET=""

# OpenAI (for AI triage assessment)
OPENAI_API_KEY="sk-..."

# Razorpay Payment Gateway
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_..."

# Email (SMTP — Gmail example)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# WhatsApp Business API (optional)
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# Seed data (optional — only for initial setup)
# SEED_ADMIN_PASSWORD="strong-password-here"
# SEED_SUPERADMIN_PASSWORD="strong-password-here"
# ALLOW_SEED=1
